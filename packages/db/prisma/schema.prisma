// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum ScanStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum LinkResult {
  OK
  BROKEN
  REDIRECT
  BROKEN_ANCHOR
}

enum LinkLifecycle {
  NEW
  RECURRING
  FIXED
}

enum AlertSchedule {
  NONE
  DAILY
  WEEKLY
}

// ---------------------------------------------------------------------------
// MODELS
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth.js session tables
  accounts Account[]
  sessions Session[]

  sites Site[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Site {
  id          String   @id @default(cuid())
  userId      String
  rootUrl     String
  name        String
  scanOptions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans       Scan[]
  alertConfig AlertConfig?

  // one active scan at a time — enforced in application layer and here as guidance
  @@index([userId])
  @@map("sites")
}

model Scan {
  id           String     @id @default(cuid())
  siteId       String
  status       ScanStatus @default(QUEUED)
  startedAt    DateTime?
  finishedAt   DateTime?
  pagesCrawled Int        @default(0)
  healthScore  Int?
  errorMessage String?
  createdAt    DateTime   @default(now())

  site       Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pages      Page[]
  linkChecks LinkCheck[]

  @@index([siteId, createdAt(sort: Desc)])
  @@map("scans")
}

model Page {
  id                 String   @id @default(cuid())
  scanId             String
  url                String
  httpStatus         Int
  title              String?
  hasMetaDescription Boolean  @default(false)
  depth              Int      @default(0)
  crawledAt          DateTime @default(now())

  scan       Scan        @relation(fields: [scanId], references: [id], onDelete: Cascade)
  linkChecks LinkCheck[] @relation("SourcePage")

  @@index([scanId])
  @@map("pages")
}

model LinkCheck {
  id            String        @id @default(cuid())
  scanId        String
  sourcePageId  String
  targetUrl     String
  isExternal    Boolean       @default(false)
  result        LinkResult
  httpStatus    Int?
  redirectChain Json?         // string[] of intermediate URLs
  errorDetail   String?
  lifecycle     LinkLifecycle @default(NEW)
  checkedAt     DateTime      @default(now())

  scan       Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  sourcePage Page @relation("SourcePage", fields: [sourcePageId], references: [id], onDelete: Cascade)

  @@index([scanId, result])
  @@index([scanId, lifecycle])
  @@map("link_checks")
}

model AlertConfig {
  id           String        @id @default(cuid())
  siteId       String        @unique
  emailEnabled Boolean       @default(false)
  webhookUrl   String?
  schedule     AlertSchedule @default(NONE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("alert_configs")
}
